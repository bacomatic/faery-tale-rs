# Local RAG demo defaults for scripts/rag_demo.sh
# Copy this file (for example to .env) and source it before running.

OLLAMA_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text
ASK_LLM_MODEL=llama3.2

INDEX_ROOT=.
INDEX_DB=.rag/index.sqlite
INDEX_EXT=rs,md,toml
INDEX_CHUNK_LINES=40
INDEX_OVERLAP_LINES=8
INDEX_RESET=true

ONLY_EXT=rs
ASK_TOP_K=5
ASK_MAX_CONTEXT_CHARS=8000
ASK_SHOW_SOURCES=true
ASK_CODE_FIRST=true
