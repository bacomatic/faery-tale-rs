#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

bash scripts/plan_sync_check.sh
bash scripts/check_docs_links.sh

# Validate faery.toml parses correctly
python3 -c "import tomllib; tomllib.load(open('faery.toml','rb'))" \
  && echo "faery.toml: OK" \
  || { echo "faery.toml: PARSE ERROR"; exit 1; }
